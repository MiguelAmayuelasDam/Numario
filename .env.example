# ── PostgreSQL (usado por docker compose) ─
POSTGRES_USER=finper
POSTGRES_PASSWORD=finper
POSTGRES_DB=finper

# ── Backend ──────────────────────────────
# En docker compose el host de la DB es "postgres"; en local, "localhost".
DATABASE_URL=postgresql+psycopg://finper:finper@localhost:5432/finper
JWT_SECRET_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── IA ───────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── App ──────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173

# ── Frontend ─────────────────────────────
VITE_API_URL=http://localhost:8000
