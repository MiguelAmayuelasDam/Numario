# ── PostgreSQL (usado por docker compose) ─
POSTGRES_USER=numario
POSTGRES_PASSWORD=numario
POSTGRES_DB=numario

# ── Backend ──────────────────────────────
# En docker compose el host de la DB es "postgres"; en local, "localhost".
DATABASE_URL=postgresql+psycopg://numario:numario@localhost:5432/numario
JWT_SECRET_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# Rate limiting en login (formato slowapi "<n>/<periodo>").
RATE_LIMIT_LOGIN=5/minute

# ── IA ───────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── App ──────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173

# ── Frontend ─────────────────────────────
VITE_API_URL=http://localhost:8000

# ── Producción (Fase 7) ──────────────────
# Referencia de qué hay que definir en cada plataforma. NO se usa en local.
#
# Render (backend, Docker):
#   DATABASE_URL=postgresql+psycopg://<user>:<pass>@<host>/<db>?sslmode=require
#     └─ cadena de Neon (Postgres gestionado, no caduca). Ojo: el driver es
#        "postgresql+psycopg://" (Neon la da como "postgresql://").
#   JWT_SECRET_KEY=<secreto largo y aleatorio>   ← la app NO arranca sin esto
#   ENVIRONMENT=production
#   CORS_ORIGINS=https://<tu-app>.vercel.app     ← la URL del frontend
#   RATE_LIMIT_LOGIN=5/minute
#   PORT lo inyecta Render automáticamente.
#   Health Check Path: /ping   ← sin BD, para no despertar a Neon (100 h/mes)
#
# Vercel (frontend, root = frontend/):
#   VITE_API_URL=https://<tu-servicio>.onrender.com   ← se usa al COMPILAR
